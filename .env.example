# ---- Core ----
APP_ENV=development
SECRET_KEY=change-me-to-a-random-string

# ---- Database (async URL, note the +asyncpg driver) ----
# Local docker-compose (host port 55432 -> avoids native PostgreSQL on 5432/5433):
DATABASE_URL=postgresql+asyncpg://pultrack:pultrack@localhost:55432/pultrack
# Neon/Supabase example:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?ssl=require

# ---- Redis (optional; leave empty to use in-memory fallback) ----
REDIS_URL=redis://localhost:6379/0

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-BotFather
# Public HTTPS base URL where Telegram sends webhook updates.
# Leave empty in local dev to run the bot in long-polling mode instead.
WEBHOOK_BASE_URL=
# Random secret that Telegram echoes back so we can verify the webhook.
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret

# ---- AI provider ----
# "local" = FREE, offline (rule-based parser + faster-whisper). No API key.
# "openai" = paid OpenAI (only if you set OPENAI_API_KEY below).
AI_PROVIDER=local
WHISPER_MODEL=base            # tiny|base|small|medium (bigger = better, slower)
WHISPER_LANGUAGE=uz           # force language for local whisper ("" = auto)

# ---- Groq (FREE Whisper large-v3 — recommended for voice) ----
# Get a free key at https://console.groq.com/keys (no card). If set, it is
# used for voice automatically — best Uzbek quality and works on free hosting.
GROQ_API_KEY=

# ---- OpenAI (optional, only when AI_PROVIDER=openai) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ---- Auth / CORS ----
# Allowed frontend origins (comma-separated). "*" = any (dev only).
CORS_ORIGINS=*

# ---- Dashboard ----
# For the single-tenant demo the dashboard shows this Telegram user's data.
# Leave empty to show the most recently active user.
DASHBOARD_USER_ID=
